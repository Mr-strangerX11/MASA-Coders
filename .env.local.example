# Copy this file to .env.local and fill in the values

# MongoDB Connection
MONGODB_URI=mongodb+srv://masacoders_db_user:Master123kashi@masa.fueec9u.mongodb.net/masacoders

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin credentials (used for seeding)
ADMIN_EMAIL=info@masacoders.tech
ADMIN_PASSWORD=Admin@123456

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email Configuration (for contact form and password resets)
EMAIL_SERVICE=gmail
EMAIL_FROM=your-email@gmail.com
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
# Or if using custom SMTP:
# EMAIL_HOST=your-smtp-host.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-smtp-user
# EMAIL_PASSWORD=your-smtp-password

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
